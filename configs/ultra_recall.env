# 超大召回 + 完整回答提示词优化
# 目标：准确率 35% → 45-50%

# ==================== 检索参数（超大数据召回）====================
RETRIEVAL_VECTOR_TOP_K=15
RETRIEVAL_KEYWORD_TOP_K=15
RETRIEVAL_GRAPH_MAX=12

# 重排序召回倍数：从 4 增大到 5
RERANK_RECALL_MULT=5

# RRF 常数
RRF_K=60

# 重排序文档上限：增加到 20
RERANK_DOC_CAP=20

# ==================== 提示词配置 ====================
# 温度：保持 0.1
OPENAI_TEMPERATURE=0.1

# ==================== 严格模式 ====================
# 宽松模式
KB_STRICT_ONLY=false
INTERNAL_DOC_ONLY_ANSWER=false

# ==================== 评估配置 ====================
# 使用 crud_optimized_v2（完整回答强调）
EVAL_PROMPT_STYLE=crud_optimized_v2