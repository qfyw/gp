# CRUD_RAG 最佳实践配置
# 基于论文和代码探索得出的优化参数

# ==================== 检索参数（核心优化）====================
# chunk_size 从 600 降到 128（CRUD_RAG 最佳实践）
# 原因：更小的 chunk 减少噪声，提高检索精度
INGEST_CHUNK_SIZE=128
INGEST_CHUNK_OVERLAP=0

# 重叠从 0 改为 50（保持上下文连续性）
# 原因：避免上下文断裂，特别是跨句的信息
INGEST_CHUNK_OVERLAP=50

# top_k 从 12 降到 8（CRUD_RAG 默认值）
# 原因：减少低质量结果，降低噪声
RETRIEVAL_VECTOR_TOP_K=8
RETRIEVAL_KEYWORD_TOP_K=8
RETRIEVAL_GRAPH_MAX=8
BM25_TOP_K=8

# 重排序召回倍数从 5 降到 3
# 原因：balance 召回质量和效率
RERANK_RECALL_MULT=3

# RRF 常数（与 CRUD_RAG 一致）
RRF_K=60

# ==================== 提示词配置 ====================
# 温度从默认降到 0.1（CRUD_RAG 最佳实践）
OPENAI_TEMPERATURE=0.1

# 最大生成 tokens
OPENAI_MAX_TOKENS=1280

# ==================== 严格模式 ====================
# 评测时使用宽松模式（减少 false_abstain）
KB_STRICT_ONLY=false
INTERNAL_DOC_ONLY_ANSWER=false

# ==================== 评估配置 ====================
# 使用 eval_optimized 模式
EVAL_PROMPT_STYLE=eval_optimized

# 并发数（CRUD_RAG 默认）
NUM_THREADS=20