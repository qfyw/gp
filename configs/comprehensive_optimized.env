# 综合优化配置
# 结合 CRUD_RAG 最佳实践 + 自定义优化

# ==================== 检索参数（平衡召回和精度）====================
# chunk_size: 128（CRUD_RAG 最佳实践）
INGEST_CHUNK_SIZE=128
# chunk_overlap: 50（保持上下文连续性）
INGEST_CHUNK_OVERLAP=50

# top_k: 10（CRUD_RAG 默认 8，我们略微增大）
RETRIEVAL_VECTOR_TOP_K=10
RETRIEVAL_KEYWORD_TOP_K=10
RETRIEVAL_GRAPH_MAX=10
BM25_TOP_K=10

# 重排序召回倍数: 4（balance）
RERANK_RECALL_MULT=4

# RRF 常数（与 CRUD_RAG 一致）
RRF_K=60

# ==================== 提示词配置 ====================
# 温度: 0.1（CRUD_RAG 最佳实践）
OPENAI_TEMPERATURE=0.1

# 最大生成 tokens
OPENAI_MAX_TOKENS=1280

# ==================== 严格模式 ====================
# 评测时使用宽松模式（减少 false_abstain）
KB_STRICT_ONLY=false
INTERNAL_DOC_ONLY_ANSWER=false

# ==================== 评估配置 ====================
# 使用 crud_optimized 模式
EVAL_PROMPT_STYLE=crud_optimized

# 并发数（CRUD_RAG 默认）
NUM_THREADS=20