# 进一步优化配置：增大召回 + 改进提示词
# 目标：准确率 50% → 55%

# ==================== 检索参数（增大召回）====================
RETRIEVAL_VECTOR_TOP_K=12
RETRIEVAL_KEYWORD_TOP_K=12
RETRIEVAL_GRAPH_MAX=10

# 重排序召回倍数：从 3 增大到 4
RERANK_RECALL_MULT=4

# RRF 常数
RRF_K=60

# ==================== 提示词配置 ====================
# 温度：从 0.1 保持不变
OPENAI_TEMPERATURE=0.1

# ==================== 严格模式 ====================
# 宽松模式
KB_STRICT_ONLY=false
INTERNAL_DOC_ONLY_ANSWER=false

# ==================== 评估配置 ====================
# 使用 crud_optimized 改进版
EVAL_PROMPT_STYLE=crud_optimized_v2