# 优化配置 - 提升召回率，减少拒答
# 复制到 .env 或运行评测时导出

# 增大召回数量，减少漏检
RETRIEVAL_VECTOR_TOP_K=12
RETRIEVAL_KEYWORD_TOP_K=12
RETRIEVAL_GRAPH_MAX=12

# 放宽严格模式（只在评测时使用）
KB_STRICT_ONLY=false
INTERNAL_DOC_ONLY_ANSWER=false

# 提升重排序召回倍数
RERANK_RECALL_MULT=5

# 入库切分优化（减少上下文断裂）
INGEST_CHUNK_SIZE=400
INGEST_CHUNK_OVERLAP=100