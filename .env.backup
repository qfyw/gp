# 复制为 .env 并填写（可选）
#
# LLM：OpenAI 兼容接口（可接 DeepSeek / 通义千问 / Kimi 等）
OPENAI_API_KEY=sk-de027d7c15ba4756b871857e3262644a
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-flash


# Web Search (Tavily)
TAVILY_API_KEY=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

# HuggingFace 镜像（国内网络推荐）
HF_ENDPOINT=https://hf-mirror.com

# 混合检索默认 top-k（与网页端、run_eval 默认一致；可按需改）
# 错题归因多属检索上下文弱：略增 k（延迟会升）
RETRIEVAL_VECTOR_TOP_K=8
RETRIEVAL_KEYWORD_TOP_K=8
RETRIEVAL_GRAPH_MAX=10

# 检索重排序（CrossEncoder；首次运行会下载 RERANK_MODEL，约数百 MB）
RERANK_ENABLED=1
# RERANK_MODEL=BAAI/bge-reranker-base
RERANK_RECALL_MULT=5
# 重排后文档 chunk 上限：不设置或留空 = 默认 cap = vector+keyword+BM25_TOP_K（如 8+8+5=21）
# 合成提示每条内部片段字数：默认见 config INTERNAL_DOC_PROMPT_CHARS=1100，可在此覆盖
# INTERNAL_DOC_PROMPT_CHARS=1100
# 入库切块（改后须清空向量集合并重新入库，勿与旧 chunk 混用）
# INGEST_CHUNK_SIZE=600
# INGEST_CHUNK_OVERLAP=120
# RERANK_DOC_CAP=
# RERANK_MAX_PASSAGE_CHARS=1800

# URL 入库抓取时是否校验 HTTPS 证书（默认 true）。
# 若遇到 SSL: CERTIFICATE_VERIFY_FAILED，可临时设为 false（仅建议开发环境）。
WEB_FETCH_VERIFY_SSL=true

# 嵌入模型（默认使用 sentence-transformers，首次会从 HuggingFace 下载）
# 切到 CRUD 测试库时使用 BGE（768维）
EMBEDDING_MODEL=BAAI/bge-base-zh-v1.5
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# 若模型已下载到本地目录，可设为本地路径并仅用本地文件，避免联网：
# EMBEDDING_MODEL=D:/models/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_LOCAL_ONLY=true

# PostgreSQL + pgvector（向量库 + 关键词检索）
# 你需要在 PostgreSQL 中安装扩展：vector（pgvector），可选 pg_trgm（提升中文关键词检索效果）
# 示例（按你的用户名/密码/库名修改）：
POSTGRES_DSN=postgresql://postgres:123456@localhost:5432/rag
# 可选：向量集合名（默认 rag_docs）
# 切到 CRUD 测试库
PGVECTOR_COLLECTION=crud_eval
# 显式指定命名空间（关键词表/docs_index/图谱文件隔离）
KB_NAMESPACE=crud_eval

# 知识图谱入库：KG_LLM_INGEST_RATE 0=不调 LLM（大批量快）1=每段 LLM（慢、边更多）
# CRUD-RAG 风格：大批量入库不依赖 LLM 抽图
KG_LLM_INGEST_RATE=0
# CRUD-RAG 常见切块参数
INGEST_CHUNK_SIZE=128
INGEST_CHUNK_OVERLAP=0
KB_STRICT_ONLY=true
DOC_ONLY_MODE=false
INTERNAL_DOC_ONLY_ANSWER=true
# 问题含 SkyCampus 等专有词时：正文/来源都匹配不到则不要回退成全量误召回（默认 true）
RETRIEVAL_DISTINCTIVE_STRICT=true
